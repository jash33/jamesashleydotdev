---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Writing by James Ashley.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;
const isBlog = path === base || path === base + '/' || path.startsWith(base + '/writing');
const isAbout = path.startsWith(base + '/about');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="container">
      <header class="site-header">
        <a href={base} class="site-name">James Ashley</a>
        <nav class="site-nav">
          <a href={base} class={isBlog ? 'active' : ''}>Writing</a>
          <a href={`${base}/about`} class={isAbout ? 'active' : ''}><del>About</del></a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      <div class="container">
        © {new Date().getFullYear()} James Ashley
      </div>
    </footer>
  </body>
</html>
